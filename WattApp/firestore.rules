rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.members;
      match /todos/{todoId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.members;
      }
      // Ajoute ici les mêmes règles pour comments, activity, etc.
    }
  }
}

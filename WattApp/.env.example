# Configuration des clés API pour WattApp
# ⚠️ Copiez ce fichier en .env et remplissez vos vraies clés

# HuggingFace API Key (100% GRATUIT)
# Obtenez votre clé sur: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_token_here

# OpenRouter API Key (optionnel)
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE

# Stripe Keys (si nécessaire)
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
